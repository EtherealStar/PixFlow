                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.pixflow</groupId>
                <artifactId>pixflow-module-file</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.pixflow</groupId>
                <artifactId>pixflow-module-memory</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.pixflow</groupId>
                <artifactId>pixflow-module-commerce</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.pixflow</groupId>
                <artifactId>pixflow-module-dag</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.pixflow</groupId>
                <artifactId>pixflow-module-vision</artifactId>
                <version>${project.version}</version>
