        <module>pixflow-module-commerce</module>
        <module>pixflow-module-dag</module>
        <module>pixflow-module-vision</module>
        <module>pixflow-module-imagegen</module>
        <module>pixflow-module-task</module>
        <module>pixflow-module-rubrics</module>
